# Copy this file to .env.local and fill in real values. .env.local is
# gitignored (see the root .gitignore) - never commit it.
#
# Both of these come from Supabase Dashboard -> Project Settings -> API.
# Only the anon (public) key belongs here - the frontend is read-only and
# relies on RLS (db/schema.sql) to allow public reads. The service_role key
# is backend-only and lives in worker/.env / GitHub Actions secrets instead.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

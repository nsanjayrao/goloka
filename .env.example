# Copy this file to .env and fill in real values. .env is gitignored - never commit it.

# Google Cloud Console -> APIs & Services -> Credentials -> Create API key,
# then enable "YouTube Data API v3" for the project. No billing account needed.
YOUTUBE_API_KEY=

# Supabase Dashboard -> Project Settings -> API
SUPABASE_URL=
# Use the service_role key (secret!) - the worker needs write access.
SUPABASE_SERVICE_KEY=

# Optional: enables LLM auto-tagging for videos the keyword rules can't classify.
# Same free key you use in the RAG chatbot. Leave empty to use rules only.
GROQ_API_KEY=

# Optional: second free LLM provider (build.nvidia.com -> get API key). The
# worker fails over Groq -> NVIDIA when one rate-limits, so big enrich runs
# don't stall on a single free tier. Leave empty to use Groq alone.
NVIDIA_API_KEY=
